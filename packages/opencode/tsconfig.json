{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "jsx": "react-jsx",
        "jsxImportSource": "@opentui/solid"
    },
    "include": ["index.ts", "tui.tsx", "lib/**/*"],
    "exclude": ["node_modules", "dist", "logs"]
}
